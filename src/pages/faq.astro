---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---
<BaseLayout
  title="FAQ · Kóng台語 跳Swing"
  description="Kóng台語 跳Swing 常見問題：課程、社交舞會、工作坊與合作。"
  ogTitle="FAQ · Kóng台語 跳Swing"
  ogDescription="整理課程、社交舞會、工作坊與合作常見問題。"
  twitterTitle="FAQ · Kóng台語 跳Swing"
  twitterDescription="整理課程、社交舞會、工作坊與合作常見問題。"
  prefetch={["index.html", "about.html", "daily.html", "vocabulary.html", "events.html", "contact.html"]}
  variant="sub"
  activeNav="faq"
>
  <style is:inline slot="head" set:html={`
    body{background:var(--navy);color:var(--paper)}
    .faq{padding:28px 0 84px}
    .faq-grid{display:grid;grid-template-columns:1fr 1.4fr;gap:64px}
    .faq-list{display:flex;flex-direction:column;gap:8px}
    .qa-group{margin-bottom:26px}
    .group-title{font-family:var(--mono);font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--mustard);margin:0 0 8px}
    .qa{border-bottom:1px solid rgba(255,255,255,.18);padding:0}
    .qa-q{appearance:none;width:100%;min-height:56px;border:0;background:transparent;color:inherit;display:flex;justify-content:space-between;align-items:center;gap:24px;padding:18px 0;text-align:left;cursor:pointer;font-family:var(--serif);font-size:20px;font-weight:500}
    .qa-q:focus-visible{outline:3px solid var(--mustard);outline-offset:3px}
    .qa-q .toggle{width:28px;height:28px;border-radius:50%;background:var(--mustard);color:var(--navy);display:grid;place-items:center;font-weight:700;flex-shrink:0;transition:transform .25s ease}
    .qa.open .qa-q .toggle{transform:rotate(45deg)}
    .qa-a{max-height:0;overflow:hidden;transition:max-height .35s ease,margin-top .35s ease;color:rgba(255,255,255,.78);font-size:15px;line-height:1.7}
    .qa.open .qa-a{max-height:260px;margin-top:14px}
    .faq-side{position:sticky;top:120px;align-self:start}
    .faq-side .blockquote{font-family:var(--serif);font-size:30px;line-height:1.4;font-weight:500;color:var(--paper);border-left:4px solid var(--mustard);padding-left:18px}
    .faq-side .blockquote .poj{font-style:italic;color:var(--mustard-soft)}
    .faq-side .att{font-family:var(--hand);font-size:22px;color:var(--mustard);margin-top:14px}
    .todo{margin-top:30px;padding:22px;border:1px solid rgba(255,255,255,.2);background:rgba(255,255,255,.05);color:rgba(255,255,255,.82);line-height:1.7}
    .todo strong{color:var(--mustard)}
    @media (max-width:820px){
      .faq{padding:24px 0 64px}
      .faq-grid{grid-template-columns:1fr;gap:24px}
      .faq-side{position:static}
    }
  `}></style>

  <PageHero
    tone="navy"
    kicker="FAQ · 大家定定問"
    title="想欲問淡薄仔代誌"
    hand="ask us!"
    lede="這頁先整理常見問題的完整架構，之後會逐組補成更細的課程、社交、工作坊與其他說明。"
  />

  <section class="faq">
    <div class="wrap">
      <div class="faq-grid">
        <div class="faq-side">
          <div class="blockquote">
            “想欲用台語分享 Swing dance 佮 Jazz 文化內底 ê 熱情、自由、美麗。”
            <div class="att">— 阮 ê 第一條筆記，2023</div>
          </div>
          <div class="todo"><strong>TODO:</strong> 擴成分組顯示：課程 / 社交 / 工作坊 / 其他，並補到 12-15 條完整 FAQ。</div>
        </div>
        <div class="faq-list" id="faqlist"></div>
      </div>
    </div>
  </section>

  <script is:inline slot="afterBody">
    const faqs = [
      { group:'課程 · Classes', q:'毋捌台語會使來上課無？ / Don’t speak Tâi-gí?',
        a:'會使，逐家攏會使。阮上課用台語＋華語（雙聲道），新手嘛免緊張。網站每週「今仔日詞」嘛是攏附華語、英文。' },
      { group:'課程 · Classes', q:'我從來毋捌跳過 swing，敢有問題？',
        a:'完全無問題。Lindy Hop 初級班是 8 週課，從聽節拍 → 基本步 → social etiquette 一步一步來。第一堂課送一張兔仔貼紙。' },
      { group:'課程 · Classes', q:'課程／工作坊敢有個人折扣？',
        a:'學生、無業、原住民族友、新住民朋友憑證件有 8 折。多人報名嘛有揀組優惠，寫信來阮。' },
      { group:'社交 · Socials', q:'社交舞會一定愛帶舞伴無？',
        a:'免。Swing social 的文化是大家輪流邀舞，單獨來也很正常。新手場會有工作人員協助。' },
      { group:'社交 · Socials', q:'我只會一點點基本步，敢會使參加？',
        a:'會使。社交舞會不是考試，會聽節拍、願意禮貌邀舞就會使來。' },
      { group:'工作坊 · Workshops', q:'我是台語老師／文化機構，會使合作無？',
        a:'歡迎！阮做過國小、社大、書店、咖啡廳 ê 工作坊，從 30 分鐘到 3 點鐘 ê 形式攏會使。寫信講你欲做啥款 ê 場。' },
      { group:'工作坊 · Workshops', q:'工作坊可以客製主題嗎？',
        a:'可以。可以偏台語詞彙、社交舞入門、Jazz 文化，或是用活動目標重新設計。' },
      { group:'其他 · Other', q:'兔仔有名字無？',
        a:'伊號做「sūn-sòa」（順續）。意思是「順紲」做一寡代誌：佇路頂順紲跳一下舞。' }
    ];
    const groups = [...new Set(faqs.map(f=>f.group))];
    document.getElementById('faqlist').innerHTML = groups.map(group=>`
      <div class="qa-group">
        <h2 class="group-title">${group}</h2>
        ${faqs.filter(f=>f.group===group).map((f,i)=>{
          const idx = faqs.indexOf(f);
          return `<article class="qa${idx===0?' open':''}">
            <button class="qa-q" type="button" aria-expanded="${idx===0?'true':'false'}" aria-controls="faq-a-${idx}">
              <span>${f.q}</span><span class="toggle" aria-hidden="true">+</span>
            </button>
            <div class="qa-a" id="faq-a-${idx}" role="region" aria-hidden="${idx===0?'false':'true'}">${f.a}</div>
          </article>`;
        }).join('')}
      </div>`).join('');
    document.querySelectorAll('.qa').forEach(el=>{
      const btn = el.querySelector('.qa-q');
      const panel = el.querySelector('.qa-a');
      btn.addEventListener('click',()=>{
        const open = !el.classList.contains('open');
        el.classList.toggle('open', open);
        btn.setAttribute('aria-expanded', String(open));
        panel.setAttribute('aria-hidden', String(!open));
      });
    });
  </script>
</BaseLayout>
