---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
import ContactChannels from '../components/ContactChannels.astro';
import InfoCardGrid from '../components/InfoCardGrid.astro';

const todoCards = [
  { title: 'TODO · 合作專案', body: '補上工作坊形式、可合作單位、活動規模與過往案例。' },
  { title: 'TODO · 贊助方案', body: '整理單次贊助、內容製作支持、活動贊助與曝光方式。' },
  { title: 'TODO · Media kit', body: '補上品牌素材、Logo、照片、短介紹與媒體下載連結。' },
];
---
<BaseLayout
  title="聯絡 · Kóng台語 跳Swing"
  description="聯絡 Kóng台語 跳Swing：合作、贊助、工作坊邀請、媒體訪問與社群管道。"
  ogTitle="聯絡 · Kóng台語 跳Swing"
  ogDescription="合作、贊助、工作坊邀請、媒體訪問與社群管道。"
  twitterTitle="聯絡 · Kóng台語 跳Swing"
  twitterDescription="合作、贊助、工作坊邀請、媒體訪問與社群管道。"
  prefetch={["index.html", "about.html", "daily.html", "vocabulary.html", "events.html", "faq.html"]}
  variant="sub"
  activeNav="contact"
>
  <style is:inline slot="head" set:html={`
    body{background:radial-gradient(920px 620px at 0 0,rgba(28,58,142,.10),transparent 60%),var(--paper)}
    @media (min-width:821px){body{background-attachment:fixed}}
    .contact .lede{font-size:18px;max-width:680px}
    .contact{padding:36px 0 72px}
    .contact-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:48px;align-items:start}
    @media (max-width:820px){
      .contact{padding:28px 0 56px}
      .contact-grid{grid-template-columns:1fr;gap:32px}
    }
  `}></style>

  <PageHero
    kicker="Contact · 講予阮聽"
    title="合作、贊助、招舞、講閒仔話"
    hand="攏歡迎"
    lede="欲招阮去你 ê 學校、咖啡廳、書店辦小型工作坊？抑是想欲贊助阮做更多免費內容？填底下 ê 表單，抑是寄一張 e-mail 來嘛會使。"
  />

  <section class="contact">
    <div class="wrap">
      <div class="contact-grid">
        <ContactForm />
        <ContactChannels />
      </div>
    </div>
  </section>

  <InfoCardGrid items={todoCards} />

  <script is:inline slot="afterBody">
    (function(){
      const form = document.getElementById('contact-form');
      if (!form) return;
      const submit = form.querySelector('.submit');
      const status = form.querySelector('.form-status');
      const submitOriginal = submit.textContent;
      const COLOR_OK = 'var(--moss)';
      const COLOR_ERR = 'var(--rust)';
      const COLOR_DEFAULT = 'var(--ink-soft)';

      function setStatus(text, color){
        status.style.color = color;
        status.textContent = text;
      }

      form.addEventListener('submit', async (e)=>{
        e.preventDefault();
        if (!form.reportValidity()) return;
        const fd = new FormData(form);
        const data = {
          name: fd.get('name'),
          email: fd.get('email'),
          topic: fd.get('topic'),
          message: fd.get('message'),
        };
        submit.disabled = true;
        submit.textContent = '送出中…';
        setStatus('傳送中，請稍等。', COLOR_DEFAULT);
        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(data),
          });
          const body = await res.json().catch(()=>({ ok:false }));
          if (res.ok && body.ok) {
            submit.textContent = '送出囉 ✦ 多謝!';
            setStatus('表單已送出，阮會盡快回覆 lí。', COLOR_OK);
            form.reset();
            setTimeout(()=>{ submit.textContent = submitOriginal; submit.disabled = false; }, 4000);
          } else {
            submit.textContent = submitOriginal;
            submit.disabled = false;
            const msg = body.error === 'bad_email' ? 'Email 格式有誤，請再確認。'
                     : body.error === 'missing_fields' ? '請填寫姓名、Email 與訊息。'
                     : body.error === 'mail_not_configured' ? '寄信服務尚未上線，請改寄 IG 私訊予阮。'
                     : '送出失敗，請過一下再試，或改寄 IG 私訊予阮。';
            setStatus(msg, COLOR_ERR);
          }
        } catch (err) {
          submit.textContent = submitOriginal;
          submit.disabled = false;
          setStatus('連線異常，請過一下再試。', COLOR_ERR);
        }
      });
    })();
  </script>
</BaseLayout>
