---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="聯絡 · Kóng台語 跳Swing"
  description="聯絡 Kóng台語 跳Swing：合作、贊助、工作坊邀請、媒體訪問與社群管道。"
  ogTitle="聯絡 · Kóng台語 跳Swing"
  ogDescription="合作、贊助、工作坊邀請、媒體訪問與社群管道。"
  twitterTitle="聯絡 · Kóng台語 跳Swing"
  twitterDescription="合作、贊助、工作坊邀請、媒體訪問與社群管道。"
  prefetch={["index.html", "about.html", "vocabulary.html", "events.html", "faq.html"]}
  variant="sub"
  activeNav="contact"
>
  <style is:inline slot="head" set:html={`
    body{background:radial-gradient(920px 620px at 0 0,rgba(28,58,142,.10),transparent 60%),var(--paper)}
    @media (min-width:821px){body{background-attachment:fixed}}
    .page-hero{padding:64px 0 28px}
    .kicker{font-family:var(--mono);font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:var(--navy)}
    h1{font-family:var(--serif);font-size:clamp(40px,5vw,72px);font-weight:700;margin:8px 0 0;line-height:1.05}
    h1 .hand{font-family:'Shadows Into Light';color:var(--navy);font-size:.55em;display:inline-block;transform:rotate(-2deg)}
    .lede{font-size:18px;color:var(--ink-soft);max-width:680px;margin:18px 0 0;line-height:1.7}
    .contact{padding:36px 0 72px}
    .contact-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:48px;align-items:start}
    .contact-form{display:grid;gap:14px;background:#fdfaf1;padding:32px;border:1px solid var(--line)}
    .field{display:grid;gap:6px}
    .field label{font-family:var(--mono);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--navy)}
    .field input,.field select,.field textarea{padding:12px 14px;border:1px solid var(--line);background:var(--paper);font:inherit;font-size:16px;color:var(--ink);outline:none;border-radius:0}
    .field input:focus,.field select:focus,.field textarea:focus{border-color:var(--navy);background:#fff}
    .field textarea{resize:vertical;min-height:130px}
    .row2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .submit{margin-top:6px;display:inline-flex;align-items:center;justify-content:center;gap:10px;min-height:44px;background:var(--navy);color:var(--paper);border:0;padding:14px 22px;border-radius:999px;font-size:15px;font-family:inherit;letter-spacing:.04em;cursor:pointer}
    .submit:hover{background:var(--navy-deep)}
    .submit:disabled{cursor:wait;opacity:.74}
    .channels{display:grid;gap:14px}
    .ch{display:flex;align-items:center;gap:18px;padding:18px;background:#fdfaf1;border:1px solid var(--line);text-decoration:none;color:var(--ink);transition:transform .15s ease,border-color .15s ease}
    .ch:hover{transform:translateY(-2px);border-color:var(--navy)}
    .ch .ic{width:42px;height:42px;border-radius:50%;background:var(--mustard);display:grid;place-items:center;color:var(--navy);font-family:var(--serif);font-weight:900;flex:0 0 42px}
    .ch .name{font-family:var(--serif);font-size:18px;font-weight:600;line-height:1}
    .ch .meta{font-size:13px;color:var(--ink-soft);margin-top:4px;line-height:1.45}
    .todo{padding:40px 0 84px;border-top:1px solid var(--line)}
    .todo-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
    .todo-card{background:#fdfaf1;border:1px solid var(--line);padding:22px}
    .todo-card h2{font-family:var(--serif);font-size:24px;margin:0 0 10px;color:var(--navy)}
    .todo-card p{margin:0;color:var(--ink-soft);line-height:1.7}
    @media (max-width:820px){
      .page-hero{padding:48px 0 20px}
      .contact{padding:28px 0 56px}
      .contact-grid{grid-template-columns:1fr;gap:32px}
      .contact-form{padding:24px}
      .todo-grid{grid-template-columns:1fr}
    }
    @media (max-width:560px){
      .row2{grid-template-columns:1fr}
    }
  `}></style>

  <section class="page-hero">
    <div class="wrap">
      <div class="kicker">Contact · 講予阮聽</div>
      <h1>合作、贊助、招舞、講閒仔話 <span class="hand">攏歡迎</span></h1>
      <p class="lede">
        欲招阮去你 ê 學校、咖啡廳、書店辦小型工作坊？抑是想欲贊助阮做更多免費內容？
        填底下 ê 表單，抑是寄一張 e-mail 來嘛會使。
      </p>
    </div>
  </section>

  <section class="contact">
    <div class="wrap">
      <div class="contact-grid">
        <form class="contact-form" id="contact-form" novalidate>
          <div class="row2">
            <div class="field"><label for="n">名 · Name</label><input id="n" name="name" type="text" autocapitalize="words" autocomplete="name" required placeholder="Lí ê miâ"></div>
            <div class="field"><label for="e">Email</label><input id="e" name="email" type="email" autocomplete="email" required placeholder="hello@..."></div>
          </div>
          <div class="field">
            <label for="t">主題 · Topic</label>
            <select id="t" name="topic">
              <option>合作 · Collaboration</option>
              <option>贊助 · Sponsorship</option>
              <option>邀請工作坊 · Workshop invite</option>
              <option>媒體訪問 · Press</option>
              <option>其他 · Other</option>
            </select>
          </div>
          <div class="field"><label for="m">訊息 · Message</label><textarea id="m" name="message" required placeholder="講予阮聽..."></textarea></div>
          <button class="submit" type="submit">送出 · Send →</button>
          <p class="form-status" role="status" aria-live="polite" style="margin:0;color:var(--ink-soft);font-size:13px"></p>
        </form>

        <div class="channels">
          <a class="ch" href="https://www.instagram.com/kongswing/" target="_blank" rel="noreferrer">
            <span class="ic">IG</span>
            <div>
              <div class="name">@kongswing</div>
              <div class="meta">逐禮拜更新 / weekly posts · 6.4k</div>
            </div>
          </a>
          <a class="ch" href="mailto:hello@kongswing.cc">
            <span class="ic" style="background:var(--navy);color:var(--mustard)">@</span>
            <div>
              <div class="name">hello@kongswing.cc</div>
              <div class="meta">合作 · 媒體 · 工作坊邀請</div>
            </div>
          </a>
          <a class="ch" href="https://www.facebook.com/search/top?q=K%C3%B3ng%E5%8F%B0%E8%AA%9E%20%E8%B7%B3Swing" target="_blank" rel="noreferrer">
            <span class="ic">FB</span>
            <div>
              <div class="name">Kóng台語 跳Swing</div>
              <div class="meta">活動公告 / event announcements</div>
            </div>
          </a>
          <a class="ch" href="mailto:hello@kongswing.cc?subject=%E8%B4%8A%E5%8A%A9%E5%90%88%E4%BD%9C%20Sponsor">
            <span class="ic" style="background:var(--rust);color:#fff">★</span>
            <div>
              <div class="name">贊助 · Sponsor</div>
              <div class="meta">買一杯珍奶請阮 / buy us bubble tea</div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="todo">
    <div class="wrap">
      <div class="todo-grid">
        <article class="todo-card">
          <h2>TODO · 合作專案</h2>
          <p>補上工作坊形式、可合作單位、活動規模與過往案例。</p>
        </article>
        <article class="todo-card">
          <h2>TODO · 贊助方案</h2>
          <p>整理單次贊助、內容製作支持、活動贊助與曝光方式。</p>
        </article>
        <article class="todo-card">
          <h2>TODO · Media kit</h2>
          <p>補上品牌素材、Logo、照片、短介紹與媒體下載連結。</p>
        </article>
      </div>
    </div>
  </section>

  <script is:inline slot="afterBody">
    (function(){
      const form = document.getElementById('contact-form');
      if (!form) return;
      const submit = form.querySelector('.submit');
      const status = form.querySelector('.form-status');
      const submitOriginal = submit.textContent;
      const COLOR_OK = 'var(--moss)';
      const COLOR_ERR = 'var(--rust)';
      const COLOR_DEFAULT = 'var(--ink-soft)';

      function setStatus(text, color){
        status.style.color = color;
        status.textContent = text;
      }

      form.addEventListener('submit', async (e)=>{
        e.preventDefault();
        if (!form.reportValidity()) return;
        const fd = new FormData(form);
        const data = {
          name: fd.get('name'),
          email: fd.get('email'),
          topic: fd.get('topic'),
          message: fd.get('message'),
        };
        submit.disabled = true;
        submit.textContent = '送出中…';
        setStatus('傳送中，請稍等。', COLOR_DEFAULT);
        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(data),
          });
          const body = await res.json().catch(()=>({ ok:false }));
          if (res.ok && body.ok) {
            submit.textContent = '送出囉 ✦ 多謝!';
            setStatus('表單已送出，阮會盡快回覆 lí。', COLOR_OK);
            form.reset();
            setTimeout(()=>{ submit.textContent = submitOriginal; submit.disabled = false; }, 4000);
          } else {
            submit.textContent = submitOriginal;
            submit.disabled = false;
            const msg = body.error === 'bad_email' ? 'Email 格式有誤，請再確認。'
                     : body.error === 'missing_fields' ? '請填寫姓名、Email 與訊息。'
                     : body.error === 'mail_not_configured' ? '寄信服務尚未上線，請改寄 IG 私訊予阮。'
                     : '送出失敗，請過一下再試，或改寄 IG 私訊予阮。';
            setStatus(msg, COLOR_ERR);
          }
        } catch (err) {
          submit.textContent = submitOriginal;
          submit.disabled = false;
          setStatus('連線異常，請過一下再試。', COLOR_ERR);
        }
      });
    })();
  </script>
</BaseLayout>
