  <script is:inline slot="afterBody">
    // Ticker
    const tickerWords = [
      "thiàu-bú · 跳舞 · to dance",
      "iô-pái · 搖擺 · swing",
      "im-ga̍k · 音樂 · music",
      "chò-hóe · 做伙 · together",
      "tńg-chhù · 轉厝 · go home",
      "thò͘-á · 兔仔 · rabbit",
      "chū-iû · 自由 · freedom",
      "jia̍t-chêng · 熱情 · passion"
    ];
    const t = document.getElementById('ticker');
    const tHTML = tickerWords.map(w=>`<span>${w}</span>`).join('');
    t.innerHTML = tHTML + tHTML;

    // Vocab card
    const words = [
      { n:1, han:'跳舞', poj:'thiàu-bú', cat:'動作 · verb',
        sen_han:'咱來開始跳舞。', sen_poj:'Lán lâi khai-sí thiàu-bú.',
        en:'to dance', zh:'跳舞', ex_en:"Let's start dancing.",
        note:'「跳舞」(thiàu-bú) 嘛會使講做「跳舞蹈」(thiàu bú-tō)。佇 Swing 內底定定講「kā 我跳一條」── 跟我跳一首。' },
      { n:2, han:'搖擺', poj:'iô-pái', cat:'形容 · adj.',
        sen_han:'這條歌真搖擺！', sen_poj:'Chit tiâu koa chin iô-pái!',
        en:'swingy, with swing feel', zh:'搖擺、有 swing 味',
        ex_en:"This tune really swings!",
        note:'iô-pái 字面是「搖搖擺擺」，佮英文 swing 真有契合 ê 意思。' },
      { n:3, han:'邀舞', poj:'iau-bú', cat:'社交 · social',
        sen_han:'我會使邀你跳一條無？', sen_poj:'Góa ē-sái iau lí thiàu chi̍t tiâu bô?',
        en:'to ask for a dance', zh:'邀請別人跳舞',
        ex_en:"May I have this dance?",
        note:'佇社交舞 (social) 內底，邀舞是基本禮數。對方會使應「好啊 (hó--ah)」抑「歹勢 (pháiⁿ-sè)」。' },
      { n:4, han:'多謝', poj:'to-siā', cat:'禮數 · etiquette',
        sen_han:'多謝你 ê 舞！', sen_poj:'To-siā lí ê bú!',
        en:'thank you (esp. after a dance)', zh:'謝謝（跳完一條尤其要說）',
        ex_en:"Thanks for the dance!",
        note:'跳完一條歌，記得行回伊 ê 邊講「多謝」。佮對方目睭看一下，誠重要。' },
      { n:5, han:'做伙', poj:'chò-hóe', cat:'副 · adv.',
        sen_han:'咱做伙來跳！', sen_poj:'Lán chò-hóe lâi thiàu!',
        en:'together, with one another', zh:'一起',
        ex_en:"Let's dance together!",
        note:'阮 ê slogan：「招逐家做伙講台語、跳 Swing」。chò-hóe 嘛會寫做「做夥」。' }
    ];

    let idx = 0;
    const card = document.getElementById('card');
    const counter = document.getElementById('counter');
    const dotsEl = document.getElementById('dots');
    const saved = new Set((function(){
      try { return JSON.parse(localStorage.getItem('kts-saved') || '[]'); }
      catch (e) { return []; }
    })());
    function persistSaved(){
      try { localStorage.setItem('kts-saved', JSON.stringify([...saved])); } catch (e) {}
    }
    function updateSaveBtn(){
      const btn = document.getElementById('btn-save');
      if (!btn) return;
      const w = words[idx];
      const isSaved = saved.has(w.n);
      btn.setAttribute('aria-pressed', String(isSaved));
      btn.style.background = isSaved ? 'var(--mustard)' : '';
      btn.style.color = isSaved ? 'var(--navy)' : '';
      btn.innerHTML = isSaved
        ? '<span class="ico">★</span> 已收藏'
        : '<span class="ico"><svg viewBox="0 0 14 14" width="14" height="14"><path fill="none" stroke="currentColor" stroke-width="1.6" d="M3 2h8v10l-4-2.5L3 12V2z"/></svg></span> 收藏';
    }

    function renderDots(){
      dotsEl.innerHTML = words.map((_,i)=>`<span class="${i===idx?'on':''}"></span>`).join('');
    }
    function setWord(i){
      idx = (i + words.length) % words.length;
      const w = words[idx];
      document.getElementById('w-han').textContent = w.han;
      document.getElementById('w-poj').textContent = w.poj;
      document.getElementById('w-sen-han').textContent = w.sen_han;
      document.getElementById('w-sen-poj').textContent = w.sen_poj;
      document.getElementById('b-han').textContent = w.han;
      document.getElementById('b-poj').textContent = w.poj + ' · ' + w.cat.split(' ')[0];
      document.getElementById('b-num').textContent = '№ ' + String(w.n).padStart(3,'0') + ' / 128';
      document.getElementById('b-en').textContent = w.en;
      document.getElementById('b-zh').textContent = w.zh;
      document.getElementById('b-cat').textContent = w.cat;
      document.getElementById('b-ex-poj').textContent = w.sen_poj;
      document.getElementById('b-ex-han').textContent = w.sen_han;
      document.getElementById('b-ex-en').textContent = w.ex_en;
      document.getElementById('b-note').textContent = w.note;
      counter.textContent = String(w.n).padStart(3,'0') + ' / ' + String(words.length).padStart(3,'0');
      renderDots();
      updateSaveBtn();
    }

    function setCardFlipped(flipped){
      card.classList.toggle('flipped', flipped);
      card.setAttribute('aria-pressed', String(flipped));
      card.setAttribute('aria-label', flipped ? '翻回今仔日詞卡正面' : '翻面查看今仔日詞的解釋');
    }
    function toggleCard(){
      setCardFlipped(!card.classList.contains('flipped'));
    }
    document.getElementById('btn-flip').addEventListener('click', toggleCard);
    card.addEventListener('click', (e)=>{
      if(e.target.closest('.pad-btn')) return;
      toggleCard();
    });
    card.addEventListener('keydown', (e)=>{
      if(e.key !== 'Enter' && e.key !== ' ') return;
      e.preventDefault();
      toggleCard();
    });
    document.getElementById('next').addEventListener('click', ()=>{ setCardFlipped(false); setWord(idx+1) });
    document.getElementById('prev').addEventListener('click', ()=>{ setCardFlipped(false); setWord(idx-1) });

    document.getElementById('btn-save').addEventListener('click', ()=>{
      const id = words[idx].n;
      saved.has(id) ? saved.delete(id) : saved.add(id);
      persistSaved();
      updateSaveBtn();
    });

    document.getElementById('btn-play').addEventListener('click', async ()=>{
      const w = words[idx];
      const btn = document.getElementById('btn-play');
      if (btn.disabled) return;
      const original = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<span class="ico">♪</span> 播音中...';
      await (window.ktsSpeak ? window.ktsSpeak(w.sen_han) : Promise.resolve(false));
      btn.innerHTML = original;
      btn.disabled = false;
    });

    setWord(0);

    // FAQ
    const faqs = [
      { q:'毋捌台語會使來上課無？ / Don’t speak Tâi-gí?',
        a:'會使，逐家攏會使。阮上課用台語＋華語（雙聲道），新手嘛免緊張。網站每週「今仔日詞」嘛是攏附華語、英文。' },
      { q:'我從來毋捌跳過 swing，敢有問題？',
        a:'完全無問題。Lindy Hop 初級班是 8 週課，從聽節拍 → 基本步 → social etiquette 一步一步來。第一堂課送一張兔仔貼紙。' },
      { q:'課程／工作坊敢有 ê 個人折扣？',
        a:'學生、無業、原住民族友 ê、新住民朋友憑證件有 8 折。多人報名嘛有揀組優惠 ── 寫信來阮。' },
      { q:'我是台語老師／文化機構，會使合作無？',
        a:'歡迎！阮做過國小、社大、書店、咖啡廳 ê 工作坊，從 30 分鐘到 3 點鐘 ê 形式攏會使。寫信講你欲做啥款 ê 場。' },
      { q:'兔仔有名字無？',
        a:'伊號做「sūn-sòa」（順續）。意思是「順紲」做一寡代誌──佇路頂順紲跳一下舞。' }
    ];
    document.getElementById('faqlist').innerHTML = faqs.map((f,i)=>`
      <article class="qa${i===0?' open':''}">
        <button class="qa-q" type="button" aria-expanded="${i===0?'true':'false'}" aria-controls="faq-a-${i}">
          <span>${f.q}</span><span class="toggle" aria-hidden="true">+</span>
        </button>
        <div class="qa-a" id="faq-a-${i}" role="region" aria-hidden="${i===0?'false':'true'}">${f.a}</div>
      </article>`).join('');
    document.querySelectorAll('.qa').forEach(el=>{
      const btn = el.querySelector('.qa-q');
      const panel = el.querySelector('.qa-a');
      btn.addEventListener('click',()=>{
        const open = !el.classList.contains('open');
        el.classList.toggle('open', open);
        btn.setAttribute('aria-expanded', String(open));
        panel.setAttribute('aria-hidden', String(!open));
      });
    });

    // Scrolling rabbit
    const sr = document.getElementById('srab');
    const srSay = document.getElementById('srab-say');
    const motionMql = window.matchMedia('(prefers-reduced-motion: reduce)');
    const sayings = [
      "咱來跳舞！", "Lán lâi thiàu-bú!", "iô-pái ~", "tâi-gí!", "swing!",
      "做伙來 →", "tńg-chhù ê lō͘", "✦ jazz ✦", "thò͘-á 跟綴中"
    ];
    let lastY = 0, hide;
    let pos = { left: 24, top: window.innerHeight*0.55, vy:0 };
    function step(){
      sr.style.left = pos.left + 'px';
      sr.style.top  = pos.top  + 'px';
    }
    step();
    function applyRabbitMotion(){
      sr.style.display = motionMql.matches ? 'none' : '';
    }
    applyRabbitMotion();
    motionMql.addEventListener?.('change', applyRabbitMotion);
    window.addEventListener('scroll', ()=>{
      if (motionMql.matches) return;
      const y = window.scrollY;
      const dy = y - lastY;
      lastY = y;
      if (Math.abs(dy) > 4) {
        sr.style.opacity = '1';
        sr.style.transform = `rotate(${dy * 0.4}deg) scaleY(${1 - Math.min(0.18, Math.abs(dy)*0.005)})`;
        pos.top = Math.max(80, Math.min(window.innerHeight - 200, pos.top + dy * 0.3));
        if (Math.random() < 0.04) {
          srSay.textContent = sayings[Math.floor(Math.random()*sayings.length)];
        }
        step();
        clearTimeout(hide);
        hide = setTimeout(()=>{
          sr.style.transform = 'rotate(0)';
        }, 200);
        clearTimeout(window.__sr_h);
        window.__sr_h = setTimeout(()=>{ sr.style.opacity = '0' }, 1400);
      }
    }, { passive:true });

    // Active nav highlight on scroll
    const sectionsList = ['about','vocab','events','faq','contact'];
    const navLinks = document.querySelectorAll('.nav-links > a');
    function activate(){
      let cur = 'about';
      for (const id of sectionsList){
        const el = document.getElementById(id);
        if (!el) continue;
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight*0.4) cur = id;
      }
      navLinks.forEach(a=>{
        a.classList.toggle('active', a.getAttribute('href') === '#'+cur);
      });
    }
    window.addEventListener('scroll', activate, { passive:true });

    // Contact form submit
    (function(){
      const form = document.getElementById('contact-form');
      if (!form) return;
      const submit = form.querySelector('.submit');
      const status = form.querySelector('.form-status');
      const submitOriginal = submit.textContent;
      const COLOR_OK = 'var(--moss)';
      const COLOR_ERR = 'var(--rust)';
      const COLOR_DEFAULT = 'var(--ink-soft)';

      function setStatus(text, color){
        status.style.color = color;
        status.textContent = text;
      }

      form.addEventListener('submit', async (e)=>{
        e.preventDefault();
        if (!form.reportValidity()) return;
        const fd = new FormData(form);
        const data = {
          name: fd.get('name'),
          email: fd.get('email'),
          topic: fd.get('topic'),
          message: fd.get('message'),
        };
        submit.disabled = true;
        submit.textContent = '送出中…';
        setStatus('傳送中，請稍等。', COLOR_DEFAULT);
        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(data),
          });
          const body = await res.json().catch(()=>({ ok:false }));
          if (res.ok && body.ok) {
            submit.textContent = '送出囉 ✦ 多謝!';
            setStatus('表單已送出，阮會盡快回覆 lí。', COLOR_OK);
            form.reset();
            setTimeout(()=>{ submit.textContent = submitOriginal; submit.disabled = false; }, 4000);
          } else {
            submit.textContent = submitOriginal;
            submit.disabled = false;
            const msg = body.error === 'bad_email' ? 'Email 格式有誤，請再確認。'
                       : body.error === 'missing_fields' ? '請填寫姓名、Email 與訊息。'
                       : body.error === 'mail_not_configured' ? '寄信服務尚未上線，請改寄 IG 私訊予阮。'
                       : '送出失敗，請過一下再試，或改寄 IG 私訊予阮。';
            setStatus(msg, COLOR_ERR);
          }
        } catch (err) {
          submit.textContent = submitOriginal;
          submit.disabled = false;
          setStatus('連線異常，請過一下再試。', COLOR_ERR);
        }
      });
    })();
  </script>
</BaseLayout>
