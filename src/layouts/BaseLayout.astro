---
import globalCss from '../styles/global.css?raw';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogTitle: string;
  ogDescription: string;
  twitterTitle: string;
  twitterDescription: string;
  prefetch: string[];
  variant: 'home' | 'sub';
  activeNav?: 'home' | 'about' | 'daily' | 'vocabulary' | 'events' | 'faq' | 'contact';
}
const {
  title,
  description,
  ogTitle,
  ogDescription,
  twitterTitle,
  twitterDescription,
  prefetch,
  variant,
  activeNav,
} = Astro.props;
---
<!doctype html>
<html lang="zh-Hant">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
<meta name="description" content={description} />
<meta property="og:title" content={ogTitle} />
<meta property="og:description" content={ogDescription} />
<meta property="og:type" content="website" />
<meta property="og:image" content="/logo.png" />
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={twitterTitle} />
<meta name="twitter:description" content={twitterDescription} />
<title>{title}</title>
<link rel="icon" href="/logo.png" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Iansui&family=Noto+Serif+TC:wght@400;500;600;700;900&family=Noto+Sans+TC:wght@400;500;700&family=Caveat:wght@600;700&family=Shadows+Into+Light&family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
{prefetch.map((href) => <link rel="prefetch" href={href} />)}
<style is:inline set:html={globalCss}></style>
<slot name="head" />
</head>
<body>
<a class="skip-link" href="#main">跳到主要內容</a>
<Nav variant={variant} activeNav={activeNav} />
{variant === 'home' && <a id="top"></a>}
<main id="main" tabindex="-1">
  <slot />
</main>
<Footer variant={variant} />
<slot name="afterFooter" />

<script is:inline>
  // shared smooth-scroll consumer (pages consume target queued before cross-page nav)
  (function(){
    let reduceMotion = false;
    const mq = window.matchMedia?.('(prefers-reduced-motion:reduce)');
    function syncMotionPreference(){
      reduceMotion = !!mq?.matches;
    }
    syncMotionPreference();
    mq?.addEventListener?.('change', syncMotionPreference);
    let target = null;
    try { target = sessionStorage.getItem('kts-smooth-target'); } catch (_) {}
    if (!target) return;
    try { sessionStorage.removeItem('kts-smooth-target'); } catch (_) {}
    const el = document.getElementById(target);
    if (!el) return;
    requestAnimationFrame(()=>{
      el.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block:'start' });
    });
  })();

  // shared smooth-scroll producer (queue target before cross-page nav)
  (function(){
    document.querySelectorAll('.nav-links a[href$=".html"]').forEach(a=>{
      a.addEventListener('click', e=>{
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button) return;
        const url = new URL(a.getAttribute('href'), location.href);
        if (url.pathname === location.pathname) return;
        const target = a.dataset.scrollTo || 'main';
        try { sessionStorage.setItem('kts-smooth-target', target); } catch (_) {}
      });
    });
  })();

  // shared language switcher
  (function(){
    const root = document.documentElement;
    let saved = 'zh';
    try {
      saved = localStorage.getItem('kts-lang') || 'zh';
    } catch (e) {}
    if (saved === 'all') saved = 'zh';
    const langMap = { zh:'zh-Hant', tw:'nan-Hant-TW', poj:'nan-Latn', en:'en' };
    function setLang(l){
      root.setAttribute('data-lang', l);
      root.setAttribute('lang', langMap[l] || 'zh-Hant');
      document.querySelectorAll('#lang-sw button').forEach(b=>{
        b.classList.toggle('on', b.dataset.lang === l);
      });
      try{ localStorage.setItem('kts-lang', l); }catch(e){}
    }
    setLang(saved);
    const sw = document.getElementById('lang-sw');
    if (sw){
      sw.addEventListener('click', e=>{
        const b = e.target.closest('button[data-lang]');
        if (b) setLang(b.dataset.lang);
      });
    }
  })();

  // shared Taiwanese speech synthesis. nan-Hant-TW 是正確的 BCP47，但實際裝置多半只有 zh-TW（國語），
  // 所以先嘗試任何 min-nan / hokkien / holo 標記的 voice，找不到才回退 zh-TW（會以國語腔讀漢字）。
  (function(){
    if (!('speechSynthesis' in window)) return;
    function pickVoice(){
      const voices = speechSynthesis.getVoices();
      return voices.find(v => /min-nan|^nan|t[âa]i|hokkien|holo/i.test(v.name + ' ' + v.lang))
          || voices.find(v => /zh-TW|zh_TW|cmn-Hant/i.test(v.lang))
          || null;
    }
    // prime voice list (Chrome/Safari load voices async on first call)
    speechSynthesis.getVoices();
    speechSynthesis.addEventListener?.('voiceschanged', () => speechSynthesis.getVoices());
    window.ktsSpeak = function(text){
      return new Promise(resolve => {
        try {
          speechSynthesis.cancel();
          const u = new SpeechSynthesisUtterance(text);
          u.lang = 'nan-Hant-TW';
          u.rate = 0.9;
          const v = pickVoice();
          if (v) u.voice = v;
          u.onend = () => resolve(true);
          u.onerror = () => resolve(false);
          speechSynthesis.speak(u);
        } catch (e) { resolve(false); }
      });
    };
  })();

  // shared mobile nav toggle
  (function(){
    const tog = document.getElementById('nav-toggle');
    const body = document.body;
    if (!tog) return;
    function close(){ body.classList.remove('nav-open'); tog.setAttribute('aria-expanded','false') }
    function open(){ body.classList.add('nav-open'); tog.setAttribute('aria-expanded','true') }
    tog.addEventListener('click', ()=>{ body.classList.contains('nav-open') ? close() : open(); });
    document.querySelectorAll('.nav-links > a').forEach(a=>a.addEventListener('click', close));
    window.addEventListener('resize', ()=>{ if (window.innerWidth > 820) close(); });
    window.addEventListener('keydown', e=>{ if (e.key === 'Escape') close(); });
  })();
</script>

<slot name="afterBody" />
</body>
</html>
