---
interface Props {
  variant: 'home' | 'sub';
  activeNav?: 'home' | 'about' | 'daily' | 'vocabulary' | 'events' | 'faq' | 'contact';
}
const { variant, activeNav } = Astro.props;
---
<nav class="nav">
  <div class="nav-inner">
    <a class="brand" href="index.html">
      <span class="brand-mark"><img src="/logo.png" alt="Kóng台語 跳Swing logo" width="370" height="370"></span>
      <span class="brand-name">Kóng台語 跳Swing<small>講台語、跳搖擺</small></span>
    </a>
    <div class="nav-menu" id="nav-menu">
      <div class="lang-sw" id="lang-sw">
        <button data-lang="zh" class="on">華</button>
        <button data-lang="tw">台</button>
        <button data-lang="poj">POJ</button>
        <button data-lang="en">EN</button>
      </div>
      <div class="nav-links">
        <a href="index.html" class:list={[activeNav === 'home' && 'active']}>首頁</a>
        <a href="about.html" class:list={[activeNav === 'about' && 'active']}>關於</a>
        <a href="daily.html" class:list={[activeNav === 'daily' && 'active']}>每日台語</a>
        <a href="vocabulary.html" class:list={[activeNav === 'vocabulary' && 'active']}>詞彙庫</a>
        <a href="events.html" class:list={[activeNav === 'events' && 'active']}>課程</a>
        <a href="faq.html" class:list={[activeNav === 'faq' && 'active']}>FAQ</a>
        <a class="nav-cta" href="contact.html" class:list={[activeNav === 'contact' && 'active']}>聯絡我們 →</a>
      </div>
    </div>
    <button class="nav-toggle" id="nav-toggle" aria-label="menu" aria-expanded="false" aria-controls="nav-menu"><span class="bars"><span></span></span></button>
  </div>
</nav>
